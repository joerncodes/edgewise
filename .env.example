# Where the markdown data is stored. In Docker this is the mounted volume.
DATA_DIR=./data

# Password used by the web UI login form.
APP_PASSWORD=change-me

# Bearer token used by API clients (curl, Claude, scripts).
# Send as: Authorization: Bearer <API_TOKEN>
API_TOKEN=change-me-too

# Auth.js signing secret (generate with: openssl rand -base64 32)
AUTH_SECRET=change-me-three

# Set in production to the public URL of the app (e.g. https://edgewise.example.com)
AUTH_URL=
